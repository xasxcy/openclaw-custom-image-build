OPENCLAW_IMAGE=ghcr.io/xasxcy/openclaw:latest

# 用于 gateway 和 CLI 之间的认证，生成方式：openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=<your-secure-token>
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./workspace

OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Channels（配置优先，环境变量回退）
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
DISCORD_BOT_TOKEN=<your-discord-bot-token>
GOG_KEYRING_PASSWORD=<your-keyring-password>

# API Keys
BRAVE_API_KEY=<your-brave-api-key>
GEMINI_API_KEY=<your-gemini-api-key>

# home 持久化
OPENCLAW_HOME_VOLUME=openclaw_home
XDG_CONFIG_HOME=/home/node/.openclaw

# Google Vertex AI
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>
GOOGLE_CLOUD_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=/root/.config/gcloud/application_default_credentials.json

# 代理（可选，留空则不走代理）
# HTTP_PROXY=http://192.168.x.x:8888
# HTTPS_PROXY=http://192.168.x.x:8888
